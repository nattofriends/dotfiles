[alias]
    sdiff = -c delta.features=side-by-side diff
    scdiff = -c delta.features=side-by-side diff --cached
    csdiff = -c delta.features=side-by-side diff --cached
[delta]
    diff-highlight = true
    navigate = true
    navigate-regex = "^diff --git"
    line-numbers-left-format = "{nm:^4}│ "
    line-numbers-right-format = "{np:^4}│ "
    wrap-right-percent = 0.01
    wrap-right-symbol = " "
    wrap-left-symbol = " "
