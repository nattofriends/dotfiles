[alias]
    co = checkout
    sm = submodule

    sttaus = status
    brnach = branch
    gpre = grep

    b = rev-parse --abbrev-ref HEAD
    br = branch --sort=-committerdate --format='%(HEAD) %(refname:short) %(color:yellow)%(objectname:short)%(color:reset) (%(color:green)%(committerdate:relative)%(color:reset))'
    # TODO: Support other fuzzy finders
    bri = "!git checkout $(git br | fzy | tr -s ' ' | cut -f2 -d' ')"
    cdiff = diff --cached
[branch]
    sort = committerdate
[color]
    ui = true
[core]
    autocrlf = false
    excludesFile = ~/.gitignore_global
    attributesFile = ~/.metaconf/git/generated/attributes
[credential]
    helper = cache --timeout 2604800
    helper = oauth -device
[diff]
    algorithm = histogram
    renames = copy
    colorMoved = default
[fetch]
    prune = true
[grep]
    lineNumber = true
[init]
    defaultBranch = main
[pull]
    ff = true
    rebase = false
[push]
    default = current
    autoSetupRemote = true
[rerere]
    enabled = true
[safe]
    directory = *
[submodule]
    fetchJobs = 0
[user]
    name = nattofriends
    email = nattofriends@gmail.com
[include]
    path = ~/.metaconf/git/generated/config
    path = ~/.gitconfig_local
